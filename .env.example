# VibzCheck environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Spotify credentials are stored in Firebase Functions config, NOT here.
# Use: firebase functions:config:set spotify.client_id="XXX" spotify.client_secret="XXX"

# Cloud Functions base URL (set after deploying)
# e.g. https://us-central1-vibzcheck.cloudfunctions.net
CLOUD_FUNCTIONS_BASE_URL=https://us-central1-TODO_PROJECT_ID.cloudfunctions.net
